{
  "name": "@clevertask/kanban-board-ui",
  "version": "0.0.10",
  "homepage": "https://github.com/clevertask/kanban-board-ui#readme",
  "bugs": {
    "url": "https://github.com/clevertask/kanban-board-ui/issues"
  },
  "license": "MIT",
  "author": "CleverTask",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clevertask/kanban-board-ui"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/kanban-board-ui.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/kanban-board-ui.js"
    },
    "./e2e": {
      "types": "./dist/e2e/utils/index.d.ts",
      "default": "./dist/e2e/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "e2e": "playwright test",
    "e2e:dev": "playwright test --ui",
    "build": "rm -rf dist && vite build && vite build -c vite.test.config.ts && tsc -p tsconfig.types.json --noCheck",
    "lint": "eslint .",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.5.0",
    "@dnd-kit/dom": "^0.5.0",
    "@dnd-kit/helpers": "^0.5.0",
    "@dnd-kit/react": "^0.5.0",
    "@radix-ui/react-icons": "^1.3.2",
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "oxfmt": "^0.42.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "react": ">=18.3.1 <20.0.0",
    "react-dom": ">=18.3.1 <20.0.0"
  }
}
